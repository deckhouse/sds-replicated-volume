        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "sum by (node, phase) (sds_rvr_count{node=~\"$node\",storage_class=~\"$storage_class\"})",
          "legendFormat": "{{node}} / {{phase}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
