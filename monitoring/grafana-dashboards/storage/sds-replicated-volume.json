    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "DRBD Out-of-Sync Bytes by Node",
      "description": "Existing DRBD exporter metric aligned with DRBD alert rules. Non-zero values indicate replication lag.",
      "datasource": {
        "type": "prometheus",
        "uid": "$ds_prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 56
      },
      "targets": [
        {
          "expr": "sum by (node) (drbd_peerdevice_outofsync_bytes{node=~\"$node\"})",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "spanNulls": false,
            "showPoints": "never"
