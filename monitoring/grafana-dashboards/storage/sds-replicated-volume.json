{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Total RVs",
      "id": 1,
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "$ds_prometheus" },
      "targets": [
        {
          "expr": "count(sds_rv_created_timestamp_seconds{storage_class=~\"$storage_class\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "auto" }
    },
    {
      "type": "stat",
      "title": "Unhealthy RVs",
      "description": "RVs older than 5 min with IOReady=False. IOReady condition is not yet populated by the controller.",
      "id": 2,
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "$ds_prometheus" },
      "targets": [
        {
          "expr": "count(sds_rv_condition{type=\"IOReady\",storage_class=~\"$storage_class\"} == 0 and on(name) (time() - sds_rv_created_timestamp_seconds{storage_class=~\"$storage_class\"} > 300))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "auto" }
    },
    {
      "type": "stat",
      "title": "Degraded RVRs",
      "id": 3,
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "$ds_prometheus" },
      "targets": [
        {
          "expr": "count(sds_rvr_phase_info{phase!=\"Healthy\",phase!=\"\",node=~\"$node\"} == 1)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "auto" }
    },
    {
      "type": "bargauge",
      "title": "Top-10 Slowest RVs",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "$ds_prometheus" },
      "targets": [
        {
          "expr": "topk(10, max by (rv) (sds_rvr_creation_duration_seconds{node=~\"$node\",storage_class=~\"$storage_class\"}))",
          "legendFormat": "{{rv}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 30 }, { "color": "red", "value": 120 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true }
    },
    {
      "type": "table",
      "title": "Per-Node Resource Count",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "$ds_prometheus" },
      "targets": [
        {
          "expr": "count by (node) (sds_rvr_phase_info{node=~\"$node\"} == 1)",
          "legendFormat": "RVRs",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "expr": "count by (node) (sds_rva_phase_info{node=~\"$node\"} == 1)",
          "legendFormat": "RVAs",
          "refId": "B",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "showHeader": true, "footer": { "show": false } },
      "transformations": [
        { "id": "merge", "options": {} }
      ]
    },
    {
      "type": "row",
      "title": "RVR Lifecycle",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false
    },
    {
      "type": "bargauge",
      "title": "Slowest RVR per RV",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "$ds_prometheus" },
      "targets": [
        {
          "expr": "max by (rv) (sds_rvr_creation_duration_seconds{node=~\"$node\",storage_class=~\"$storage_class\",rv=~\"$rv\"})",
          "legendFormat": "{{rv}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 30 }, { "color": "red", "value": 120 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true }
    },
    {
      "type": "timeseries",
      "title": "RVR Ready Duration P50/P90/P99",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "$ds_prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(sds_rvr_ready_duration_seconds_bucket{node=~\"$node\",storage_class=~\"$storage_class\"}[$__rate_interval])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(sds_rvr_ready_duration_seconds_bucket{node=~\"$node\",storage_class=~\"$storage_class\"}[$__rate_interval])) by (le))",
          "legendFormat": "P90",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(sds_rvr_ready_duration_seconds_bucket{node=~\"$node\",storage_class=~\"$storage_class\"}[$__rate_interval])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "stacking": { "mode": "none" }, "showPoints": "never" },
          "unit": "s"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
