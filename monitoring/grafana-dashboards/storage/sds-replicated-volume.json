    {
      "id": 19,
      "type": "timeseries",
      "title": "DRBD Runtime Problems by Node",
      "description": "Existing DRBD exporter metrics reused by this dashboard. Counts show current runtime problems.",
      "datasource": {
        "type": "prometheus",
        "uid": "$ds_prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 40
      },
      "targets": [
        {
          "expr": "sum by (node) (drbd_connection_state{node=~\"$node\",drbd_connection_state!=\"UpToDate\",drbd_connection_state!=\"Connected\"} == 1)",
          "legendFormat": "bad connection {{node}}",
          "refId": "A"
        },
        {
          "expr": "sum by (node) (drbd_device_quorum{node=~\"$node\"} == 0)",
          "legendFormat": "no quorum {{node}}",
          "refId": "A"
        },
        {
          "expr": "sum by (node) (drbd_device_unintentionaldiskless{node=~\"$node\"} == 1)",
          "legendFormat": "diskless {{node}}",
          "refId": "A"
        }
      ],
