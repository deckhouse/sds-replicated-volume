    {
      "id": 19,
      "type": "timeseries",
      "title": "DRBD Runtime Problems by Node",
      "description": "Current DRBD runtime problem counts by node. Zero means no matching problem.",
      "datasource": {
        "type": "prometheus",
        "uid": "$ds_prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 48
      },
      "targets": [
        {
          "expr": "sum by (node) (drbd_connection_state{node=~\"$node\",drbd_connection_state!=\"UpToDate\",drbd_connection_state!=\"Connected\"} == 1) or on(node) (0 * sum by (node) (drbd_connection_state{node=~\"$node\"}))",
          "legendFormat": "bad connection {{node}}",
          "refId": "A"
        },
        {
          "expr": "sum by (node) (drbd_device_quorum{node=~\"$node\"} == 0) or on(node) (0 * sum by (node) (drbd_device_quorum{node=~\"$node\"}))",
          "legendFormat": "no quorum {{node}}",
          "refId": "B"
        },
        {
          "expr": "sum by (node) (drbd_device_unintentionaldiskless{node=~\"$node\"} == 1) or on(node) (0 * sum by (node) (drbd_device_unintentionaldiskless{node=~\"$node\"}))",
          "legendFormat": "diskless {{node}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "spanNulls": false,
            "showPoints": "never"
