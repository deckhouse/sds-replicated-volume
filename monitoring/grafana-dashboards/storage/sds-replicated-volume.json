    {
      "id": 10,
      "type": "row",
      "title": "Performance / RVR per Node",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 13
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "RVR Ready Transition Duration P10/Avg/P90 by Node",
      "description": "Duration of every RVR Ready condition transition from non-True to True, including repeated recovery/flap transitions. Deleting RVRs are excluded. P10 highlights fast flaps, P90 highlights slow starts/recoveries; no data means there were no transitions in the selected range.",
      "datasource": {
        "type": "prometheus",
        "uid": "$ds_prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.10, sum(rate(sds_rvr_ready_transition_duration_seconds_bucket{node=~\"$node\",storage_class=~\"$storage_class\"}[$__rate_interval])) by (le, node))",
          "legendFormat": "P10 {{node}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(sds_rvr_ready_transition_duration_seconds_sum{node=~\"$node\",storage_class=~\"$storage_class\"}[$__rate_interval])) by (node) / sum(rate(sds_rvr_ready_transition_duration_seconds_count{node=~\"$node\",storage_class=~\"$storage_class\"}[$__rate_interval])) by (node)",
          "legendFormat": "avg {{node}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(sds_rvr_ready_transition_duration_seconds_bucket{node=~\"$node\",storage_class=~\"$storage_class\"}[$__rate_interval])) by (le, node))",
          "legendFormat": "P90 {{node}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 35,
      "type": "timeseries",
      "title": "RVR Ready Transition Rate by Node",
