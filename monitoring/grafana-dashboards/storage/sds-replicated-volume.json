    {
      "id": 41,
      "type": "timeseries",
      "title": "RVR Count by Phase: $node",
      "description": "Current RVR count for one node, split by phase and storage class. Zero values are shown to make missing problems explicit.",
      "datasource": {
        "type": "prometheus",
        "uid": "$ds_prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "repeat": "node",
      "repeatDirection": "h",
      "maxPerRow": 2,
      "targets": [
        {
          "expr": "sds_rvr_count{node=\"$node\",storage_class=~\"$storage_class\"}",
          "legendFormat": "{{storage_class}} / {{phase}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "spanNulls": false,
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
